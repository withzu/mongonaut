MONGO_CONNECTION_URL=""
MONGONAUT_READONLY=false
MONGONAUT_TIMEOUT=5000

DEV_REACTSCAN=false

# Authentication
# NONE | STATIC_PASSWORD | OIDC
MONGONAUT_AUTH_MODE=NONE
# Required when MONGONAUT_AUTH_MODE != NONE. Random string, min 32 chars.
MONGONAUT_AUTH_SECRET=""
# Session lifetime in seconds (default 86400 = 1 day)
MONGONAUT_SESSION_TTL=86400

# STATIC_PASSWORD
MONGONAUT_AUTH_PASSWORD=""

# Brute-force protection for STATIC_PASSWORD logins (per-IP and instance-wide)
MONGONAUT_LOGIN_MAX_ATTEMPTS=5
MONGONAUT_LOGIN_WINDOW_SECONDS=900
MONGONAUT_LOGIN_LOCKOUT_SECONDS=900
MONGONAUT_LOGIN_GLOBAL_MAX_ATTEMPTS=50
MONGONAUT_LOGIN_GLOBAL_WINDOW_SECONDS=300

# OIDC
MONGONAUT_OIDC_ISSUER=""
MONGONAUT_OIDC_CLIENT_ID=""
MONGONAUT_OIDC_CLIENT_SECRET=""
MONGONAUT_OIDC_SCOPES="openid profile email"
# Optional. If unset, derived from the incoming request as <origin>/api/auth/oidc/callback
MONGONAUT_OIDC_REDIRECT_URL=""
# Optional CSV allowlist. Empty = allow all authenticated identities.
MONGONAUT_OIDC_ALLOWED_EMAILS=""
